# Deployment Configuration
# cop to .env and fill in your values

# Private key for the deployer account (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Fee percentage in basis points (100 = 1%, 500 = 5%, 1000 = 10%)
# Default: 100 (1%)
FEE_PERCENTAGE=100

# Address that will be authorized to redeem/set winners
# Leave empty to set manually after deployment
REDEEMER_ADDRESS=

# RPC URLs for different networks

# Testnets
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
GOERLI_RPC_URL=https://eth-goerli.g.alchemy.com/v2/YOUR_API_KEY

# L2s
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

